# =============================================================================
# Configuração de ambiente — Repositório Digital CAVN
# =============================================================================

# Backend
# Gere uma SECRET_KEY forte com:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-in-production-to-a-random-string-of-at-least-50-characters
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=https://localhost,https://localhost:80,https://localhost
CORS_ALLOWED_ORIGINS=https://localhost:5173,https://localhost:80,https://localhost
# Path customizado para o Django Admin. Atualize também o location do Nginx do host.
ADMIN_URL=gerencia/

# Banco de dados
DB_ENGINE=postgresql
DB_NAME=cavn_digital
DB_USER=cavn_digital
DB_PASSWORD=cavn_digital
DB_HOST=localhost
DB_PORT=5432

# Redis — obrigatório em produção
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=change-me-in-production

# Account lockout (django-axes)
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME_MINUTES=15

# Uploads
MAX_UPLOAD_SIZE_BYTES=104857600
DATA_UPLOAD_MAX_MEMORY_SIZE=104857600
FILE_UPLOAD_MAX_MEMORY_SIZE=104857600
ALLOW_ARCHIVE_UPLOADS=True
MAX_ZIP_ENTRIES=1000
MAX_ZIP_UNCOMPRESSED_SIZE_BYTES=314572800
MAX_ZIP_COMPRESSION_RATIO=100
ANTIVIRUS_ENABLED=False
ANTIVIRUS_REQUIRED=False
ANTIVIRUS_HOST=clamav
ANTIVIRUS_PORT=3310
ANTIVIRUS_TIMEOUT_SECONDS=30

# Headers de segurança (obrigatórios quando DEBUG=False)
# O Django força HTTPS/HSTS e cookies seguros em produção. Apenas desabilite se
# estiver rodando localmente sem SSL e souber o que está fazendo — exige as
# DUAS variáveis abaixo como "True" (defesa contra desativação acidental).
# DISABLE_HTTPS_ENFORCEMENT=False
# ACKNOWLEDGE_INSECURE_HTTPS_DISABLED=False
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
REQUIRE_TOKEN_VERSION=False
MANDATORY_2FA_FOR_PRIVILEGED=False
TWO_FACTOR_ENROLLMENT_TOKEN_LIFETIME_SECONDS=600
TWO_FACTOR_LOGIN_CHALLENGE_LIFETIME_SECONDS=300
TWO_FACTOR_RECOVERY_CODE_COUNT=10
USE_X_ACCEL_REDIRECT=False
METRICS_TOKEN=
PRIVACY_REQUEST_SLA_DAYS=15
PRIVACY_DPO_NAME=Responsável institucional pela privacidade
PRIVACY_DPO_EMAIL=cavn@ufpb.br

# Monitoramento (opcional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.05

# Flower — obrigatório em produção
FLOWER_BASIC_AUTH=admin:strong-password-here

# Frontend
VITE_API_URL=http://localhost:8000/api/v1
VITE_SITE_URL=http://localhost:5173
VITE_FEEDBACK_FORM_URL=https://forms.gle/example
VITE_WEB_VITALS_SAMPLE_RATE=0.1
