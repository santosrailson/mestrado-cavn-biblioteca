# =============================================================================
# Exemplo de configuração do Nginx no host (VPS)
# =============================================================================
# Este arquivo deve ser colocado em /etc/nginx/sites-available/ (ou equivalente)
# no servidor host. Ele atua como reverse proxy para os containers Docker.
#
# Containers esperados:
#   - frontend → 127.0.0.1:3000
#   - backend  → 127.0.0.1:8000
#
# Comandos úteis:
#   sudo nginx -t
#   sudo systemctl reload nginx
# =============================================================================

# Limita requisições em endpoints sensíveis (login, refresh)
limit_req_zone $binary_remote_addr zone=auth:10m rate=5r/m;
limit_req_zone $binary_remote_addr zone=api:10m rate=100r/m;

server {
    listen 80;
    server_name bibliotecadigital.cchsa-cavn.tec.br;

    # Redirecionar HTTP para HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name bibliotecadigital.cchsa-cavn.tec.br;

    # Certificados SSL (ajuste conforme seu provedor: Let's Encrypt, Cloudflare, etc.)
    ssl_certificate /caminho/para/seu/certificado.crt;
    ssl_certificate_key /caminho/para/seu/certificado.key;

    # Logs
    access_log /var/log/nginx/cavn-access.log;
    error_log /var/log/nginx/cavn-error.log;

    # Headers de segurança globais
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;

    # Compressão
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_types
        text/plain
        text/css
        text/xml
        text/javascript
        application/json
        application/javascript
        application/xml+rss
        application/atom+xml
        image/svg+xml;

    # Arquivos estáticos do Django (servidos diretamente pelo Nginx)
    location /static/ {
        alias /opt/cavn-digital/backend/staticfiles/;
        expires 30d;
        access_log off;
        add_header Cache-Control "public, immutable" always;
    }

    # Arquivos de mídia do Django (servidos diretamente pelo Nginx)
    location /media/ {
        alias /opt/cavn-digital/backend/media/;
        expires 30d;
        access_log off;
        add_header Cache-Control "public, immutable" always;
    }

    # Backend — API, admin do Django
    location ~ ^/(api/v1|django-admin)/ {
        limit_req zone=api burst=20 nodelay;
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_redirect off;
    }

    # Proteção extra para endpoints de autenticação
    location ~ ^/api/v1/auth/(login|refresh|token)/ {
        limit_req zone=auth burst=5 nodelay;
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_redirect off;
    }

    # Frontend — aplicação React (SPA)
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_redirect off;
    }
}
