# =============================================================================
# Repositório Digital CAVN — Backend Django
# =============================================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA comite o arquivo .env no controle de versão.
# =============================================================================

# Geral
DEBUG=True
SECRET_KEY=change-me-in-production-use-a-strong-random-key
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# Banco de dados (postgresql ou sqlite)
DB_ENGINE=postgresql
DB_NAME=cavn_digital
DB_USER=cavn_digital
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Redis (cache, sessões, Celery broker)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# E-mail (SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@cavn.ufpb.br

# Segurança (habilite em produção)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Armazenamento de mídia
MEDIA_ROOT=media
MEDIA_URL=/media/
STATIC_ROOT=staticfiles
STATIC_URL=/static/

# Limites
MAX_UPLOAD_SIZE_BYTES=104857600
DATA_UPLOAD_MAX_MEMORY_SIZE=104857600
FILE_UPLOAD_MAX_MEMORY_SIZE=104857600
ALLOW_ARCHIVE_UPLOADS=True
MAX_ZIP_ENTRIES=1000
MAX_ZIP_UNCOMPRESSED_SIZE_BYTES=314572800
MAX_ZIP_COMPRESSION_RATIO=100

# Internacionalização
LANGUAGE_CODE=pt-br
TIME_ZONE=America/Fortaleza

# Sentry (opcional)
SENTRY_DSN=
